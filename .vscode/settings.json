{
    "chat.mcp.gallery.enabled": true,
    "editor.copilot.enable": {
        "*": false
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.dragAndDrop": false,
    "editor.editContext": false,
    "editor.emptySelectionClipboard": false,
    "editor.fontSize": 15,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.formatOnPaste": false,
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "editor.inlineSuggest.experimental.emptyResponseInformation": false,
    "editor.mouseWheelZoom": true,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.parameterHints.enabled": false,
    "editor.quickSuggestions": {
        "comments": "off",
        "other": "off",
        "strings": "off"
    },
    "editor.selectionClipboard": false,
    "editor.suggestOnTriggerCharacters": false,
    "editor.wordBasedSuggestions": "off",
    "files.autoSave": "off",
    "files.refactoring.autoSave": false,
    "githubPullRequests.createOnPublishBranch": "never",
    "gitlens.gitCommands.skipConfirmations": [
        "fetch:command",
        "stash-push:command",
        "switch:command"
    ],
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.debug.settings.onBuildFailureProceed": true,
    "maven.terminal.favorites": [
        {
            "command": "clean compile install  -e -X",
            "debug": false
        },
        {
            "command": "spring-boot:run -Dspring-boot.run.fork=false",
            "debug": false
        }
    ],
    "maven.view": "hierarchical",
    "screencastMode.keyboardOptions": {
        "showKeys": false,
        "showKeybindings": false,
        "showCommands": false,
        "showSingleEditorCursorMoves": false
    },
    "settingsSync.ignoredExtensions": [],
    "terminal.integrated.copyOnSelection": false,
    "terminal.integrated.localEchoLatencyThreshold": 0,
    "terminal.integrated.localEchoStyle": "dim",
    "java.compile.nullAnalysis.mode": "disabled",
    "[java]": {
        "editor.defaultFormatter": "redhat.java"
    }
}